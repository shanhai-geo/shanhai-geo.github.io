# ═══════ LLM引擎密钥 ═══════
ZHIPU_API_KEY=your_zhipu_key_here
SILICONFLOW_API_KEY=your_siliconflow_key_here
VOLCENGINE_API_KEY=your_volcengine_key_here

# ═══════ 管理员 ═══════
ADMIN_KEY=your_admin_password_here

# ═══════ 安全配置 ═══════
CORS_ORIGINS=https://shanhai-geo.github.io,https://your-domain.com
DATA_REGION=cn-north
AUDIT_LOG=true

# ═══════ 可选 ═══════
# REQUIRE_KEY=true          # 开启后chat需要298密钥
# KEYS_FILE=/data/keys.json # 密钥持久化路径
# PORT=9000                 # 服务端口

# ═══════ 298激活密钥池 ═══════
